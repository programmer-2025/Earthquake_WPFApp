<Window x:Class="Earthquake_WPFApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Earthquake_WPFApp"
        mc:Ignorable="d"
        Title="MainWindow" Height="150" Width="800">
    <Grid Background="AliceBlue">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"></ColumnDefinition>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="*"></RowDefinition>
            <RowDefinition Height="*"></RowDefinition>
        </Grid.RowDefinitions>

        <Grid Grid.Column="0" Grid.Row="1" Background="#333030">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
                <ColumnDefinition Width="*"></ColumnDefinition>
            </Grid.ColumnDefinitions>

            <Grid.RowDefinitions>
                <RowDefinition Height="*"></RowDefinition>
                <RowDefinition Height="*"></RowDefinition>
            </Grid.RowDefinitions>

            <Rectangle Grid.Column="0" Grid.RowSpan="2" Fill="#FF36373E" ></Rectangle>
            <TextBlock Grid.Column="0" Grid.Row="0"  Text="最大震度" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Name="ScaleText" Grid.Column="0" Grid.Row="1"  Text="○" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            
            <TextBlock Name="DateText" Grid.Column="1" Grid.Row="0" Text="yyyy/MM/dd hh:mm" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Name="LocationNameText" Grid.Column="1" Grid.Row="1" Text="○○県沖" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Grid.Row="0" Text="深さ" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Name="DepthText" Grid.Column="2" Grid.Row="1" Text="○km" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="3" Grid.Row="0" Text="マグニチュード" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            <TextBlock Name="MagnitudeText" Grid.Column="3" Grid.Row="1" Text="M0.0" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        </Grid>
    </Grid>
</Window>
